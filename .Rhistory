library(tidyverse)
# Tentar carregar o CSV
cat("=== DIAGNÓSTICO DO CSV ===\n\n")
# 1. Verificar se o arquivo existe
if (file.exists("tabela2000_2025.csv")) {
cat("✓ Arquivo encontrado\n")
} else {
cat("✗ Arquivo NÃO encontrado\n")
stop("Arquivo tabela2000_2025.csv não existe no diretório de trabalho")
}
# 2. Ler o CSV
cat("\n--- Lendo CSV ---\n")
tabulador_dados <- read.csv("tabela2000_2025.csv", sep=";", stringsAsFactors = FALSE, encoding = "UTF-8")
# 3. Verificar dimensões
cat("Dimensões:", nrow(tabulador_dados), "linhas x", ncol(tabulador_dados), "colunas\n")
# 4. Verificar nomes das colunas
cat("\nNomes das colunas:\n")
print(names(tabulador_dados))
# 5. Verificar primeiras linhas
cat("\nPrimeiras 5 linhas:\n")
print(head(tabulador_dados, 5))
# 6. Verificar tipos de dados
cat("\nTipos de dados:\n")
print(str(tabulador_dados))
# 7. Verificar se há colunas vazias
cat("\nColunas vazias:\n")
empty_cols <- names(tabulador_dados)[colSums(is.na(tabulador_dados)) == nrow(tabulador_dados)]
if (length(empty_cols) == 0) {
cat("Nenhuma coluna vazia\n")
} else {
cat("Colunas vazias:", paste(empty_cols, collapse = ", "), "\n")
}
# 8. Tentar renomear e converter
cat("\n--- Tentando renomear e converter ---\n")
try({
colnames(tabulador_dados) <- c("ano", "idade_cat", "tp_sexo", "st_indigena", "co_dsei_aldeia", "ds_dsei_aldeia", "frequencia")
cat("✓ Renomeação bem-sucedida\n")
cat("\nNomes após renomeação:\n")
print(names(tabulador_dados))
# Tentar mutate
cat("\n--- Tentando mutate ---\n")
tabulador_dados <- tabulador_dados %>%
mutate(
ano = as.character(ano),
idade_cat = as.character(idade_cat),
tp_sexo = as.character(tp_sexo),
st_indigena = as.character(st_indigena),
co_dsei_aldeia = as.character(co_dsei_aldeia),
ds_dsei_aldeia = as.character(ds_dsei_aldeia),
frequencia = as.numeric(frequencia)
)
cat("✓ Mutate bem-sucedido\n")
# Remover NAs
cat("\n--- Removendo NAs ---\n")
tabulador_dados <- tabulador_dados %>% filter(!is.na(frequencia))
cat("✓ Remoção de NAs bem-sucedida\n")
cat("Linhas após remoção de NAs:", nrow(tabulador_dados), "\n")
# Sucesso!
cat("\n✓ SUCESSO! Os dados foram carregados corretamente.\n")
cat("\nResumo final:\n")
print(summary(tabulador_dados))
}, error = function(e) {
cat("\n✗ ERRO durante o processamento:\n")
print(e)
})
runApp()
View(tabulador_dados)
